# ==========================================
# Local Development Settings
# ==========================================
# Dummy keys for local Docker testing
AWS_ACCESS_KEY_ID="dummy_key"
AWS_SECRET_ACCESS_KEY="dummy_secret"
AWS_REGION="us-east-1"
AWS_S3_BUCKET_NAME="dummy_bucket"

# Database Configuration (for local Docker PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@lms-db:5432/lms_db?schema=public"

# ==========================================
# Production / GitHub Secrets
# ==========================================
# Make sure to add these exact keys to your GitHub Repository Secrets 
# before running the deploy workflows:
#
# 1. AWS_ACCESS_KEY_ID       (Your real AWS IAM Access Key)
# 2. AWS_SECRET_ACCESS_KEY   (Your real AWS IAM Secret Key)
# 3. AWS_REGION              (e.g., ap-south-1)
# 4. AWS_S3_BUCKET_NAME      (e.g., lms-frontend-production)
# 5. VITE_API_URL            (Your live backend API URL, e.g., https://api.yourdomain.com/api)
# 6. DATABASE_URL            (Your live PostgreSQL database string)
# 7. JWT_SECRET              (A strong random string for authentication)