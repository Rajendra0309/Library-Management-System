generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  password       String
  role           String    @default("member") // "admin", "librarian", "member"
  phone          String?
  membershipId   String?   @unique
  status         String    @default("active") // "active", "suspended", "expired"
  // Staff-specific fields
  department     String?
  employeeId     String?   @unique
  // Location filtering fields
  city           String?
  libraryName    String?
  // Account lockout fields
  loginAttempts    Int       @default(0)
  lockUntil        DateTime?
  // Security question (for forgot password fallback step 1)
  securityQuestion String?
  securityAnswer   String?   // stored as bcrypt hash
  // OTP reset fields (fallback step 2 — shown on-screen)
  resetOtp         String?
  resetOtpExpiry   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  passwordChangedAt DateTime?


  reservations Reservation[]
  borrows      Borrow[]
  fines        Fine[]
  passwordHistory PasswordHistory[]
  notifications Notification[]
}

model Book {
  id String @id @default(cuid())

  // Basic Information
  title  String
  author String
  isbn   String @unique

  // Classification
  genre       String
  language    String?
  publisher   String
  publishYear Int?

  // Description
  description String?

  // Inventory
  totalCopies     Int @default(1)
  availableCopies Int @default(1)
  timesBorrowed   Int @default(0)

  // Digital Assets (AWS S3)
  coverImage String?
  ebookUrl   String?

  // Location & Format Filtering
  format      String? @default("physical") // "physical", "ebook", "both"
  city        String?
  libraryName String?

  // Barcode
  barcode String?

  // Audit Fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  reservations Reservation[]
  borrows      Borrow[]
}

model Reservation {
  id         String    @id @default(cuid())
  reservedAt DateTime  @default(now())
  expiresAt  DateTime?
  status     String    @default("pending") // "pending", "fulfilled", "cancelled", "expired"
  notified   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  memberId String
  bookId   String

  member User @relation(fields: [memberId], references: [id])
  book   Book @relation(fields: [bookId], references: [id])
}

model Borrow {
  id           String    @id @default(cuid())
  issueDate    DateTime
  dueDate      DateTime
  returnDate   DateTime?
  status       String    @default("active") // "active", "returned", "overdue"
  renewalCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  memberId String
  bookId   String

  member User @relation(fields: [memberId], references: [id])
  book   Book @relation(fields: [bookId], references: [id])

  fines Fine[]
}

model PasswordHistory {
  id        String   @id @default(cuid())
  userId    String
  hash      String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Fine {
  id          String    @id @default(cuid())
  amount      Float
  daysOverdue Int
  status      String    @default("pending") // "pending", "paid", "waived"
  paidAt      DateTime?
  waivedBy    String?
  reason      String? // Mandatory if waived
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  memberId String
  borrowId String

  member User   @relation(fields: [memberId], references: [id])
  borrow Borrow @relation(fields: [borrowId], references: [id])
}

model Report {
  id              String   @id @default(cuid())
  date            DateTime @default(now())
  totalBooks      Int
  totalMembers    Int
  activeBorrows   Int
  overdueBorrows  Int
  totalFines      Float?
  genreStats      Json?
  borrowingTrends Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // "info", "warning", "success", "error"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemConfig {
  id                String   @id @default("global")
  loanPeriod        Int      @default(14)
  maxBorrows        Int      @default(5)
  fineRate          Float    @default(0.25)
  reservationExpiry Int      @default(48)
  autoRenew         Boolean  @default(true)
  preDueReminders   Boolean  @default(true)
  enforceFineCaps   Boolean  @default(false)
  updatedAt         DateTime @updatedAt
}