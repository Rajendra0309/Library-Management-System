generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  password     String
  role         String    @default("member") // "admin", "librarian", "member"
  phone        String?
  membershipId String?   @unique
  status       String    @default("active") // "active", "suspended", "expired"
  profileImage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  reservations Reservation[]
  borrows      Borrow[]
}

model Book {
  id              String   @id @default(cuid())
  title           String
  author          String
  coverImage      String?
  isbn            String   @unique
  barcode         String?  @unique
  genre           String[]
  language        String   @default("English")
  publisher       String?
  publishYear     Int?
  description     String?
  totalCopies     Int      @default(1)
  availableCopies Int      @default(0)
  isEbook         Boolean  @default(false)
  ebookUrl        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reservations Reservation[]
  borrows      Borrow[]
}

model Reservation {
  id         String   @id @default(cuid())
  reservedAt DateTime @default(now())
  expiresAt  DateTime?
  status     String   @default("pending") // "pending", "fulfilled", "cancelled", "expired"
  notified   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  memberId String
  bookId   String

  member User @relation(fields: [memberId], references: [id])
  book   Book @relation(fields: [bookId], references: [id])
}

model Borrow {
  id           String    @id @default(cuid())
  issueDate    DateTime
  dueDate      DateTime
  returnDate   DateTime?
  status       String    @default("active") // "active", "returned", "overdue"
  renewalCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  memberId String
  bookId   String

  member User @relation(fields: [memberId], references: [id])
  book   Book @relation(fields: [bookId], references: [id])
}
